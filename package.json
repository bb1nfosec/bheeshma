{
  "name": "bheeshma",
  "version": "2.1.1",
  "description": "Runtime dependency behavior monitor for Node.js — the strace for npm packages. Detects supply-chain attacks that static analysis misses. Zero dependencies. Zero config. Zero telemetry.",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "bin": {
    "bheeshma": "bin/bheeshma.js",
    "bheeshma-ci": "bin/bheeshma-ci.js",
    "bheeshma-install": "bin/bheeshma-install.js"
  },
  "exports": {
    ".": {
      "require": "./src/index.js",
      "types": "./src/index.d.ts"
    }
  },
  "scripts": {
    "test": "node test/harness.js && node test/cli.test.js",
    "test:unit": "node test/harness.js",
    "test:cli": "node test/cli.test.js",
    "benchmark": "node benchmark/run.js"
  },
  "sideEffects": false,
  "keywords": [
    "security",
    "supply-chain",
    "supply-chain-security",
    "supply-chain-attack",
    "runtime-monitoring",
    "dependency-analysis",
    "behavioral-security",
    "npm-security",
    "npm-audit",
    "malware-detection",
    "malware",
    "trojan-detection",
    "backdoor",
    "ransomware",
    "pattern-detection",
    "http-monitoring",
    "dns-monitoring",
    "crypto-miner-detection",
    "cryptojacking",
    "data-exfiltration",
    "credential-theft",
    "backdoor-detection",
    "obfuscation-detection",
    "dns-tunneling",
    "ci-cd",
    "devsecops",
    "github-actions",
    "sarif",
    "code-scanning",
    "policy-enforcement",
    "npm-install",
    "postinstall",
    "preinstall",
    "shai-hulud",
    "axios-compromise",
    "typosquat",
    "pentesting",
    "red-team",
    "threat-intelligence",
    "zero-dependencies",
    "zero-config",
    "strace",
    "esm",
    "worker-threads",
    "hacktoberfest"
  ],
  "author": "bb1nfosec",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bb1nfosec/bheeshma.git"
  },
  "bugs": {
    "url": "https://github.com/bb1nfosec/bheeshma/issues"
  },
  "homepage": "https://bb1nfosec.github.io/bheeshma/",
  "files": [
    "src/",
    "bin/",
    ".github/actions/bheeshma/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ]
}
